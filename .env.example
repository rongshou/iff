# 天权留学选校推荐引擎 - 环境变量
TIANQUAN_APP_NAME=天权留学选校推荐引擎
TIANQUAN_APP_VERSION=2.0.0
TIANQUAN_DB_PATH=/app/data/advisor.db
TIANQUAN_DATA_DIR=/app/data
